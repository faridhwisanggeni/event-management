generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

model Event {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar(200)
  location  String   @db.VarChar(200)
  startsAt  DateTime @map("starts_at") @db.Timestamptz(3)
  endsAt    DateTime @map("ends_at") @db.Timestamptz(3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  attendees Attendee[]
  conciergeSessions ConciergeSession[]

  @@index([startsAt])
  @@map("events")
}

model Attendee {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  name       String   @db.VarChar(120)
  headline   String?  @db.VarChar(200)
  bio        String?  @db.Text
  company    String?  @db.VarChar(120)
  roleId     String?  @map("role_id") @db.Uuid
  skills     String[] @default([])
  lookingFor String?  @map("looking_for") @db.Text
  openToChat Boolean  @default(true) @map("open_to_chat")
  embedding  Unsupported("vector(1536)")?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  event             Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  role              Role?              @relation(fields: [roleId], references: [id], onDelete: SetNull)
  conciergeSessions ConciergeSession[]

  @@index([eventId])
  @@index([eventId, roleId])
  @@index([skills], type: Gin)
  @@map("attendees")
}

model Role {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(40)
  label     String   @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  attendees Attendee[]

  @@index([sortOrder])
  @@map("attendee_roles")
}

model ConciergeSession {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  attendeeId String   @map("attendee_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  event    Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  attendee Attendee           @relation(fields: [attendeeId], references: [id], onDelete: Cascade)
  messages ConciergeMessage[]

  @@unique([eventId, attendeeId])
  @@map("concierge_sessions")
}

model ConciergeMessage {
  id               String        @id @default(uuid()) @db.Uuid
  sessionId        String        @map("session_id") @db.Uuid
  role             ConciergeRole
  content          String?       @db.Text
  toolCalls        Json?         @map("tool_calls")
  toolCallId       String?       @map("tool_call_id") @db.VarChar(64)
  toolName         String?       @map("tool_name") @db.VarChar(64)
  matches          Json?         @map("matches")
  promptTokens     Int?          @map("prompt_tokens")
  completionTokens Int?          @map("completion_tokens")
  latencyMs        Int?          @map("latency_ms")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(3)

  session  ConciergeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  feedback Feedback?

  @@index([sessionId, createdAt])
  @@map("concierge_messages")
}

model Feedback {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @unique @map("message_id") @db.Uuid
  rating    Int
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)

  message ConciergeMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("concierge_feedback")
}

enum ConciergeRole {
  USER
  ASSISTANT
  TOOL
  SYSTEM

  @@map("concierge_role")
}

