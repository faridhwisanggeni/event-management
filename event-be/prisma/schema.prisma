generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id        String   @id @default(uuid()) @db.Uuid
  title     String   @db.VarChar(200)
  location  String   @db.VarChar(200)
  startsAt  DateTime @map("starts_at") @db.Timestamptz(3)
  endsAt    DateTime @map("ends_at") @db.Timestamptz(3)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  attendees Attendee[]

  @@index([startsAt])
  @@map("events")
}

model Attendee {
  id         String   @id @default(uuid()) @db.Uuid
  eventId    String   @map("event_id") @db.Uuid
  name       String   @db.VarChar(120)
  headline   String?  @db.VarChar(200)
  bio        String?  @db.Text
  company    String?       @db.VarChar(120)
  role       AttendeeRole?
  skills     String[]      @default([])
  lookingFor String?  @map("looking_for") @db.Text
  openToChat Boolean  @default(true) @map("open_to_chat")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(3)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(3)

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId])
  @@index([eventId, role])
  @@index([skills], type: Gin)
  @@map("attendees")
}

enum AttendeeRole {
  BACKEND_DEVELOPER
  FRONTEND_DEVELOPER
  FULLSTACK_DEVELOPER
  PROJECT_MANAGER
  PRODUCT_OWNER
  CHIEF_TECHNOLOGY_OFFICER
  HEAD_OF_ENGINEERING
  ENGINEERING_MANAGER
  DATABASE_ADMINISTRATOR
  DEVOPS
  DEVSECOPS
  NETWORK_ENGINEERING

  @@map("attendee_role")
}
