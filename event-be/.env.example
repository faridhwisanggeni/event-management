# Server
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# Database (host machine connection — for running outside docker)
DATABASE_URL=postgresql://eventmgmt:eventmgmt@localhost:5432/eventmgmt?schema=public

# LLM (OpenAI). Leave OPENAI_API_KEY blank to disable real calls (concierge will return a stub).
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMS=1536

# Concierge agent
CONCIERGE_MAX_TOOL_ITERATIONS=6
CONCIERGE_LLM_TIMEOUT_MS=30000

# FastAPI score_match microservice (Priority 3 — leave empty to use built-in fallback)
SCORE_MATCH_URL=

